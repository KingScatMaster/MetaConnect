<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#000000"
    android:gravity="center_horizontal">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MetaConnect"
        android:textSize="32sp"
        android:textColor="#4FC3F7"
        android:textStyle="bold"
        android:layout_marginTop="32dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Always-on Claude Voice Assistant"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginBottom="32dp" />

    <!-- Status -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Service not running"
        android:textSize="18sp"
        android:textColor="#F44336"
        android:textAlignment="center"
        android:padding="16dp"
        android:background="#111111"
        android:layout_marginBottom="24dp" />

    <!-- Server URL -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Server URL"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/serverInput"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:textColor="#E0E0E0"
        android:textColorHint="#555555"
        android:background="#111111"
        android:padding="12dp"
        android:textSize="14sp"
        android:hint="https://your-server.ngrok-free.dev"
        android:inputType="textUri"
        android:singleLine="true"
        android:layout_marginBottom="16dp" />

    <!-- Test Button -->
    <Button
        android:id="@+id/testBtn"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Test Connection"
        android:textColor="#000000"
        android:backgroundTint="#888888"
        android:layout_marginBottom="8dp" />

    <!-- Start / Stop -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <Button
            android:id="@+id/startBtn"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="Start"
            android:textSize="18sp"
            android:textColor="#000000"
            android:backgroundTint="#4FC3F7"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/stopBtn"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="Stop"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#F44336"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Response display -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Last Response"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginBottom="4dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#111111"
        android:padding="12dp">

        <TextView
            android:id="@+id/responseText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Responses will appear here..."
            android:textSize="16sp"
            android:textColor="#E0E0E0" />
    </ScrollView>

    <!-- Instructions -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap Start, then lock your phone. Say 'Hey Claude' any time."
        android:textSize="12sp"
        android:textColor="#555555"
        android:textAlignment="center"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp" />

</LinearLayout>
